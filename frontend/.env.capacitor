# API-URL für native Builds (Vite-Mode "capacitor"). Überschreibt .env nur beim
# Bauen der App-Hülle – der Web-Build/Dev-Server bleibt bei .env (localhost).
# Android-Emulator erreicht den Host-PC unter 10.0.2.2.
# Echtes Gerät: hier (oder in .env.capacitor.local) die LAN-IP des PCs eintragen.
VITE_API_URL=http://10.0.2.2:8080/api/v1
