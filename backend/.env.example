APP_NAME=FamilyBoard
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Sail-Ports neben XAMPP (XAMPP belegt 80 und 3306)
APP_PORT=8080
FORWARD_DB_PORT=3307
VITE_PORT=5180
WWWGROUP=1000
WWWUSER=1000

# Frontend (React-SPA, Vite-Dev-Server) – für CORS/Sanctum
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=familyboard
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Sanctum: erlaubte Stateful-Domains fürs SPA (Cookie-Auth)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5180,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Medien-Disk "s3" -> lokales MinIO (ADR-0014). Einfacheres Setup ohne
# MinIO/Redis: MEDIA_DISK=public und QUEUE_CONNECTION=sync setzen.
MEDIA_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3-kompatibler Objektspeicher für Medien in Produktion (ADR-0014, z. B.
# Hetzner Object Storage oder MinIO). Dann MEDIA_DISK=s3 setzen.
# Lokales MinIO (S3-kompatibel). Produktion: Hetzner Object Storage – nur diese
# Werte ersetzen. AWS_ENDPOINT = interne Server-Adresse, AWS_URL = öffentliche
# URL fürs Browser-<img>.
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=media
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/media
AWS_USE_PATH_STYLE_ENDPOINT=true

# MinIO-Admin (vom compose-Service genutzt)
MINIO_ROOT_USER=sail
MINIO_ROOT_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
