# =============================================================================
# Nidula – Produktions-Template (ADR-0025). NIE mit echten Werten committen!
# Auf dem Server als .env ablegen (Dateirechte 600, Besitzer = Deploy-User).
# Platzhalter in GROSSBUCHSTABEN ersetzen. Nach Änderungen:
#   php artisan config:cache && php artisan route:cache
# =============================================================================

APP_NAME=Nidula
APP_ENV=production
# php artisan key:generate --show  -> Wert hier eintragen (niemals wiederverwenden)
APP_KEY=
APP_DEBUG=false
# MUSS die öffentliche HTTPS-Adresse sein – daraus entstehen signierte
# Medien-URLs (ADR-0015) und die Kalender-Feed-URL (ADR-0024).
APP_URL=https://DEINE-DOMAIN.de
APP_LOCALE=de
APP_FAKER_LOCALE=de_DE

# SPA-Origin (CORS): exakt EINE Produktions-Origin, kein Wildcard (ADR-0025).
FRONTEND_URL=https://DEINE-DOMAIN.de

LOG_CHANNEL=stack
# Keine Debug-Details in Prod-Logs (ADR-0025: keine Stacktraces an Nutzer).
LOG_LEVEL=warning

# --- Datenbank (nur privates Netz erreichbar, ADR-0025) ---------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nidula
DB_USERNAME=nidula
# Langes Zufallspasswort, z. B.: openssl rand -base64 32
DB_PASSWORD=

# --- Sessions/Cookies (Web-SPA über HTTPS, ADR-0025) ------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Nur die eigene Domain, kein führender Punkt nötig, kein Wildcard.
SESSION_DOMAIN=DEINE-DOMAIN.de
SESSION_SECURE_COOKIE=true
# Sanctum: exakt die Hosts des SPA (mit Port nur falls abweichend von 443).
SANCTUM_STATEFUL_DOMAINS=DEINE-DOMAIN.de
# Bearer-Token-Laufzeit native Apps: 90 Tage (Review H-03).
SANCTUM_TOKEN_EXPIRATION_MINUTES=129600

# --- Queue/Cache/Redis (nur privates Netz, ADR-0025) ------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Medien: privater S3-Bucket (ADR-0014/0015, z. B. Hetzner Object Storage)
MEDIA_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central
AWS_BUCKET=nidula-media
# Hetzner Object Storage: https://fsn1.your-objectstorage.com (Beispiel FSN1)
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Mail (echter Versand, z. B. Resend/Postmark/SMTP-Anbieter) -------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hallo@DEINE-DOMAIN.de
MAIL_FROM_NAME="${APP_NAME}"

# --- Beta-Schutz (ADR-0025 Stufe 1) ------------------------------------------
# 'invite' = Registrierung NUR mit persönlicher, E-Mail-gebundener Einladung.
# Niemand Fremdes kann Konten oder Familien anlegen. Erst für eine offene
# Registrierung (Stufe 3) bewusst auf 'open' stellen.
NIDULA_REGISTRATION=invite

# --- Externe Dienste ---------------------------------------------------------
# Tankerkönig (Spritpreise, Premium): eigener Key, NIE ins Repo (ADR-0022).
TANKERKOENIG_API_KEY=
